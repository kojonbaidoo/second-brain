// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CaptureType {
  TEXT
  VOICE
  DOCUMENT
  IMAGE
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  image     String?
  emailVerified DateTime?

  createdAt DateTime  @default(now())

  captures  Capture[]

  accounts  Account[]
  sessions  Session[]
}

model Capture {
  id                String            @id @default(cuid())
  userId            String
  type              CaptureType
  processingStatus  ProcessingStatus  @default(COMPLETED)

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  user              User              @relation(fields: [userId], references: [id])
  content           CaptureContent?
  file              CaptureFile?

  processingJobs    ProcessingJob[]

  topics            CaptureTopic[]
  connectionsFrom   CaptureConnection[] @relation("from")
  connectionsTo     CaptureConnection[] @relation("to")

  @@index([userId, createdAt])
  @@index([userId, deletedAt])
}

model CaptureContent {
  id          String   @id @default(cuid())
  captureId   String   @unique
  text        String   @db.Text

  capture     Capture  @relation(fields: [captureId], references: [id], onDelete: Cascade)
}

model CaptureFile {
  id              String   @id @default(cuid())
  captureId       String   @unique

  fileUrl         String
  fileType        String
  fileSize        Int
  durationSeconds Int?

  capture         Capture  @relation(fields: [captureId], references: [id], onDelete: Cascade)
}

model ProcessingJob {
  id          String   @id @default(cuid())
  captureId   String
  status      ProcessingStatus
  attempts    Int      @default(0)
  lastError   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  capture     Capture  @relation(fields: [captureId], references: [id], onDelete: Cascade)

  @@index([captureId])
}

//
// 🔮 FUTURE TABLES (V2)
//

model Topic {
  id        String   @id @default(cuid())
  name      String

  createdAt DateTime @default(now())

  captures  CaptureTopic[]
}

model CaptureTopic {
  captureId String
  topicId   String

  capture   Capture @relation(fields: [captureId], references: [id], onDelete: Cascade)
  topic     Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([captureId, topicId])
}

model CaptureConnection {
  id              String   @id @default(cuid())
  fromCaptureId   String
  toCaptureId     String
  weight          Float?

  createdAt       DateTime @default(now())

  from            Capture  @relation("from", fields: [fromCaptureId], references: [id], onDelete: Cascade)
  to              Capture  @relation("to", fields: [toCaptureId], references: [id], onDelete: Cascade)

  @@index([fromCaptureId])
  @@index([toCaptureId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}